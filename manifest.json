{
    "manifest_version": 2.0,
    "id": "trigger_toggle_ors",
    "type": "widget",
    "name": "Trigger Toggle ORS",
    "namespace": "TriggerToggleORS",
    "version": "7.0-23",
    "author": "ORS",
    "description": "Dashboard widget to mass enable/disable triggers by filters.",
    "widget": {
        "size": {
            "width": 6,
            "height": 4
        }
    },
    "actions": {
        "widget.trigger_toggle_ors.view": {
            "class": "WidgetView"
        },
        "widget.trigger_toggle_ors.toggle": {
            "class": "WidgetToggle"
        }
    },
    "assets": {
        "css": [
            "widget.7_0_13.css",
            "form.css"
        ]
    }
}
